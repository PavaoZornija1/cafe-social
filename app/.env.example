# Clerk, API (see README)
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
#
# Simulator: http://localhost:3005/api is fine.
# Physical iPhone/Android on Wi‑Fi: use your Mac’s LAN IP (Terminal: ipconfig getifaddr en0)
# and match backend PORT, e.g. EXPO_PUBLIC_API_URL=http://192.168.1.42:3005/api
# After changing this: restart Metro (`npx expo start --clear`) or rebuild if JS is embedded from Xcode.
# EXPO_PUBLIC_API_URL=http://localhost:3005/api

# Store listings & in-app Settings → Legal (host real pages on your website)
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://yourdomain.com/terms
