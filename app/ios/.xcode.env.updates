# Sourced by the "Bundle React Native code and images" phase (see project.pbxproj).
# Default Debug skips embedding JS (SKIP_BUNDLING=1) so the app loads from Metro — fine for the simulator if `npx expo start` is running.
# Physical device: embed the bundle so "Run" from Xcode works without a packager (slower builds; use Metro when you want fast refresh).

if [[ "${PLATFORM_NAME:-}" == "iphoneos" ]]; then
  unset SKIP_BUNDLING
fi
