DATABASE_URL=postgres://postgres:password@localhost:5432/cafe-social

# Clerk sign-in (existing): JWKS + issuer from your Clerk dashboard / API keys.
# CLERK_ISSUER=https://xxx.clerk.accounts.dev
# CLERK_JWKS_URL=https://xxx.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=optional

# Clerk Backend API — required to email partner staff invites (optional; falls back to manual link).
# Also add ADMIN_PORTAL_ORIGIN to the Clerk Dashboard → Redirect URLs allowlist (e.g. https://your-admin.vercel.app/owner/accept-invite).
# CLERK_SECRET_KEY=sk_live_...
# ADMIN_PORTAL_ORIGIN=https://localhost:3000

# --- Player subscriptions (mobile) — RevenueCat → webhook updates `Subscription` / see RevenueCatModule ---
# REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer ...
# REVENUECAT_SECRET_API_KEY=...  # recommended: REST sync after webhooks
# REVENUECAT_ENTITLEMENT_ID=premium

# --- Partner / franchise SaaS (Next admin + Stripe) — updates `VenueOrganization` billing fields ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PARTNER_PRICE_ID=price_...   # default price for admin “Checkout” button
# ADMIN_PORTAL_ORIGIN must match return URLs (same as Clerk block above).

# Admin CMS / scripts — send as X-Admin-Key or Authorization: Bearer <key>
# ADMIN_API_KEY=

# Optional: Socket.IO horizontal scale (omit for single Node process)
# REDIS_URL=redis://127.0.0.1:6379

# Optional: Expo push API (higher limits / project-scoped sending)
# EXPO_ACCESS_TOKEN=

# Venue “order a drink” nudge (after continuous dwell while presence pings the API)
# VENUE_ORDER_NUDGE_ENABLED=true
# VENUE_ORDER_NUDGE_AFTER_MINUTES=30
# VENUE_ORDER_NUDGE_TITLE=Still here?
# VENUE_ORDER_NUDGE_BODY=Thirsty? Treat yourself to something from the menu at {{venueName}}.

