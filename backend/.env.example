DATABASE_URL=postgres://postgres:password@localhost:5432/cafe-social

# HTTP server (default binds 0.0.0.0 so phones on Wi‑Fi can hit your Mac during dev)
# PORT=3005
# HOST=0.0.0.0

# Clerk — same application as Expo + Next admin (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY).
#
# JWT verification uses @clerk/backend verifyToken (not raw JWKS on the Frontend API URL).
# The public https://*.clerk.accounts.dev/.well-known/jwks.json often does NOT contain the
# session signing key → jose error "no applicable key found in the JSON Web Key Set".
#
# Required for API auth + partner invites:
# CLERK_SECRET_KEY=sk_test_...
#
# Optional: networkless verify — PEM from Dashboard → API keys → "Show JWT public key"
# CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----..."
#
# Optional: if verifyToken fails with authorized parties / azp, list admin origins you use:
# CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://127.0.0.1:3000
#
# Clerk Backend API — partner staff invite emails (optional; falls back to manual link).
# Also add ADMIN_PORTAL_ORIGIN to the Clerk Dashboard → Redirect URLs allowlist.
# ADMIN_PORTAL_ORIGIN=http://localhost:3000

# --- Player subscriptions (mobile) — RevenueCat → webhook updates `Subscription` / see RevenueCatModule ---
# REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer ...
# REVENUECAT_SECRET_API_KEY=...  # recommended: REST sync after webhooks
# REVENUECAT_ENTITLEMENT_ID=premium

# --- Partner / franchise SaaS (Next admin + Stripe) — updates `VenueOrganization` billing fields ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...  # for partner in-app subscription (Stripe.js Payment Element)
# STRIPE_PARTNER_PRICE_ID=price_...   # default price for admin “Checkout” button
# ADMIN_PORTAL_ORIGIN must match return URLs (same as Clerk block above).

# Optional: POST JSON metrics (trial auto-lock, onboarding throttle) for ops / Zapier / Slack
# PARTNER_OPS_WEBHOOK_URL=

# Admin CMS / scripts — send as X-Admin-Key or Authorization: Bearer <key>
# ADMIN_API_KEY=

# Optional: Socket.IO horizontal scale (omit for single Node process)
# REDIS_URL=redis://127.0.0.1:6379

# Optional: Expo push API (higher limits / project-scoped sending)
# EXPO_ACCESS_TOKEN=

# Optional: Resend — transactional email (friend requests, party invites). Omit to skip sending.
# https://resend.com — verify a domain or use onboarding@resend.dev for tests.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Cafe Social <hello@yourdomain.com>"

# Venue “order a drink” nudge (after continuous dwell while presence pings the API)
# VENUE_ORDER_NUDGE_ENABLED=true
# VENUE_ORDER_NUDGE_AFTER_MINUTES=30
# VENUE_ORDER_NUDGE_TITLE=Still here?
# VENUE_ORDER_NUDGE_BODY=Thirsty? Treat yourself to something from the menu at {{venueName}}.

