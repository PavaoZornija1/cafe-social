generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Partner org layout: single vs multi location (drives UX and venue caps during trial).
enum VenueOrganizationKind {
  SINGLE_LOCATION
  MULTI_LOCATION
}

/// Partner organization (single- or multi-location). Multi-location orgs roll up analytics across linked venues; each venue is still a distinct location.
model VenueOrganization {
  id     String  @id @default(uuid())
  name   String
  slug   String? @unique

  /// Declared at signup; trial still caps venues until paid.
  locationKind VenueOrganizationKind @default(SINGLE_LOCATION)

  /// Self-serve trial window (partner portal). Null = no time-boxed trial (e.g. super-admin–provisioned org).
  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  /// Rate-limit / audit: player who created this org via partner onboarding.
  selfServeCreatedByPlayerId String?
  selfServeCreatedBy         Player? @relation("SelfServeOrganizationsCreated", fields: [selfServeCreatedByPlayerId], references: [id], onDelete: SetNull)

  /// Cafe Social platform billing (owner-facing); super admin maintains.
  platformBillingPlan      String?
  platformBillingStatus    String  @default("NONE")
  platformBillingRenewsAt  DateTime?
  stripeCustomerId         String?
  /// Primary Stripe Subscription id (partner SaaS); webhooks keep status in sync.
  stripeSubscriptionId     String?
  /// Optional link shown to venue owners (e.g. Stripe Customer Portal).
  billingPortalUrl         String?
  /// Last time org billing fields were updated from a Stripe webhook (Checkout/subscription events).
  platformBillingSyncedAt  DateTime?

  venues Venue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([selfServeCreatedByPlayerId])
}

/// Processed Stripe webhook events (idempotency; `id` is Stripe evt_…).
model StripeProcessedWebhookEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// A physical venue (café, bar, etc.) where games can be played.
model Venue {
  id           String  @id @default(uuid())
  name         String
  address      String?
  latitude     Float
  longitude    Float

  /// GeoJSON Polygon (WGS84, lng/lat order). Required for containment; legacy circle venues store an approximated circle polygon.
  geofencePolygon Json?

  isPremium    Boolean @default(false)

  organizationId String?
  organization   VenueOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  /// Super admin: suspend play / detection at this venue.
  locked     Boolean @default(false)
  lockReason String?

  /// Geo ladder (venue → city → country → region → global)
  city    String?
  country String?
  region  String?

  /// Optional push copy for the “order a drink” nudge (`{{venueName}}` supported).
  orderNudgeTitle String?
  orderNudgeBody  String?

  /// Menu / ordering deep links (shown in app + optional notification payload).
  menuUrl     String?
  orderingUrl String?

  /// Optional IANA timezone (e.g. `Europe/Zagreb`) for owner analytics hour-of-day buckets. UTC used when null.
  analyticsTimeZone String?

  offers VenueOffer[]

  venueVenueTypes VenueVenueType[]

  playerVenues     PlayerVenue[]
  playerVenueStats PlayerVenueStats[]
  challenges       Challenge[]
  gameSessions         GameSession[]
  playerGameVenueStats PlayerGameVenueStats[]
  feedEvents       VenueFeedEvent[]
  perks            VenuePerk[]
  visitDays        PlayerVenueVisitDay[]
  venuePlayDays    PlayerVenuePlayDay[]
  venuePlayCountedGames PlayerVenuePlayCountedGame[]
  staffMembers     VenueStaff[]
  staffInvites     VenueStaffInvite[]
  campaigns        VenueCampaign[]
  receiptSubmissions VenueReceiptSubmission[]

  /// Rate-limits marketing “send nudge now” from admin (see `VenueNudgeAdminService`).
  lastAdminNudgeBroadcastAt DateTime?

  nudgeAssignments VenueNudgeAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

/// Partner-facing venue categories (e.g. coffee, restaurant). Venues have M:N types.
model VenueType {
  id    String  @id @default(uuid())
  /// Stable code matching `VENUE_TYPE_CODES` in `src/lib/venue-taxonomy.ts`.
  code  String  @unique
  label String?

  venues            VenueVenueType[]
  nudgeTemplateLinks VenueOrderNudgeTemplateVenueType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VenueVenueType {
  venueId     String
  venueTypeId String
  venue       Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueType   VenueType @relation(fields: [venueTypeId], references: [id], onDelete: Cascade)

  @@id([venueId, venueTypeId])
  @@index([venueTypeId])
}

/// Predefined dwell nudge copy; tied to venue types via `VenueOrderNudgeTemplateVenueType`.
model VenueOrderNudgeTemplate {
  id    String @id @default(uuid())
  /// Stable key for seeds (e.g. `coffee_order_drink_v1`).
  code  String @unique
  /// Analytics bucket — see `VENUE_NUDGE_TYPES` in `src/lib/venue-taxonomy.ts`.
  nudgeType     String
  titleTemplate String
  bodyTemplate  String
  /// CMS notes (not shown in push).
  description String?
  /// Default dwell minutes before auto nudge when this template wins; null = global env default.
  defaultAfterMinutes Int?
  /// Lower sorts first when several templates match a venue’s types.
  sortPriority  Int     @default(100)
  active        Boolean @default(true)

  venueTypeLinks VenueOrderNudgeTemplateVenueType[]
  venueAssignments VenueNudgeAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortPriority])
}

/// Explicit venue ↔ template link with optional per-venue overrides (M:N). Auto dwell uses lowest `sortOrder` enabled row first; legacy type-based templates apply when this list is empty.
model VenueNudgeAssignment {
  id         String @id @default(uuid())
  venueId    String
  templateId String
  venue    Venue                   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  template VenueOrderNudgeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)
  /// Lower runs first for automatic dwell nudge selection.
  sortOrder Int @default(100)

  titleOverride        String?
  bodyOverride         String?
  afterMinutesOverride Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([venueId, templateId])
  @@index([venueId])
  @@index([templateId])
}

model VenueOrderNudgeTemplateVenueType {
  templateId  String
  venueTypeId String
  template   VenueOrderNudgeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  venueType  VenueType               @relation(fields: [venueTypeId], references: [id], onDelete: Cascade)

  @@id([templateId, venueTypeId])
  @@index([venueTypeId])
}

enum VenueOfferStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

/// Partner-configurable offers (replaces legacy `featuredOffer*` columns on `Venue`).
model VenueOffer {
  id     String @id @default(uuid())
  venueId String
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  title    String
  body     String?
  imageUrl String?
  ctaUrl   String?

  status     VenueOfferStatus @default(DRAFT)
  isFeatured Boolean          @default(false)

  validFrom DateTime?
  validTo   DateTime?

  /// Global cap; null = unlimited.
  maxRedemptions Int?
  /// Per-player cap per offer; null = unlimited redemptions per guest.
  maxRedemptionsPerPlayer Int?

  redemptionCount Int @default(0)

  redemptions VenueOfferRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
  @@index([venueId, status])
}

model VenueOfferRedemption {
  id       String     @id @default(uuid())
  offerId  String
  offer    VenueOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  playerId String
  player   Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([offerId])
  @@index([playerId])
}

enum VenueStaffInviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

model VenueStaffInvite {
  id           String                 @id @default(uuid())
  venueId      String
  email        String
  role         VenueStaffRole
  token        String                 @unique
  invitedById  String
  status       VenueStaffInviteStatus @default(PENDING)
  expiresAt    DateTime
  acceptedAt   DateTime?

  venue     Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  invitedBy Player @relation("StaffInviteSentBy", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([venueId])
  @@index([email])
}

enum CampaignStatus {
  DRAFT
  SENDING
  COMPLETED
  FAILED
}

model VenueCampaign {
  id              String         @id @default(uuid())
  venueId         String
  name            String
  title           String
  body            String
  /// Players who had any visit-day at this venue in the last N UTC days.
  segmentDays     Int            @default(30)
  status          CampaignStatus @default(DRAFT)
  recipientCount  Int?
  pushSentCount   Int            @default(0)
  lastError       String?
  sentAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  venue Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sends VenueCampaignSend[]

  @@index([venueId])
}

model VenueCampaignSend {
  id         String   @id @default(uuid())
  campaignId String
  playerId   String
  sentAt     DateTime @default(now())
  ok         Boolean  @default(true)
  error      String?

  campaign VenueCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  player   Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([playerId])
}

enum ReceiptSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model VenueReceiptSubmission {
  id                 String                  @id @default(uuid())
  venueId            String
  playerId           String
  /// Base64 image payload (data URL or raw); prefer client resize; server enforces max size in app logic.
  imageData          String                  @db.Text
  mimeType           String                  @default("image/jpeg")
  notePlayer         String?
  status             ReceiptSubmissionStatus @default(PENDING)
  staffNote          String?
  abuseFlag          Boolean                 @default(false)
  retentionUntil     DateTime?
  reviewedAt         DateTime?
  reviewedByPlayerId String?

  venue    Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  player   Player @relation("ReceiptSubmitter", fields: [playerId], references: [id], onDelete: Cascade)
  reviewer Player? @relation("ReceiptReviewer", fields: [reviewedByPlayerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, status])
  @@index([playerId])
}

/// Partner venue access: employees and owners (separate from subscription “premium”).
enum VenueStaffRole {
  EMPLOYEE
  MANAGER
  OWNER
}

/// Platform operators (Cafe Social team). Separate from per-venue VenueStaffRole.
enum PlatformRole {
  NONE
  SUPER_ADMIN
}

model VenueStaff {
  id        String         @id @default(uuid())
  venueId   String
  playerId  String
  role      VenueStaffRole @default(EMPLOYEE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([venueId, playerId])
  @@index([playerId])
}

/// A user profile inside Cafe Social.
model Player {
  id       String @id @default(uuid())
  email    String @unique
  username String @unique

  /// Cafe Social operators: full CMS + any venue via portal (Clerk JWT).
  platformRole PlatformRole @default(NONE)

  /// Open to being seen / challenged (default on). Subscribers get extra remote discoverability when this is on.
  discoverable Boolean @default(true)
  /// Total privacy: invisible to everyone for social/presence surfaces.
  totalPrivacy Boolean @default(false)

  /// Partner / venue marketing pushes (e.g. order nudge). Independent of `totalPrivacy`.
  partnerMarketingPush Boolean @default(true)
  /// Word-match join/start and similar activity pings.
  matchActivityPush    Boolean @default(true)

  /// First-time player onboarding completed (app tutorial); survives reinstall when synced from server.
  onboardingPlayerCompletedAt DateTime?
  /// Staff-only intro completed.
  onboardingStaffCompletedAt  DateTime?

  lastPresenceVenueId String?
  lastPresenceAt      DateTime?

  /// Dwell-based venue order nudge: continuous visit at `venueNudgeSessionVenueId` since `venueNudgeSessionStartedAt`.
  venueNudgeSessionVenueId   String?
  venueNudgeSessionStartedAt DateTime?
  venueNudgeLastSentAt       DateTime?

  playerVenues        PlayerVenue[]
  playerVenueStats    PlayerVenueStats[]
  subscriptions       Subscription[]
  challengeProgress   ChallengeProgress[]

  gameParticipants     GameParticipant[]
  gameStats      PlayerGameStats[]
  gameVenueStats PlayerGameVenueStats[]

  partiesCreated    Party[]       @relation("PartyCreator")
  partiesLed        Party[]       @relation("PartyLeader")
  partyMemberships  PartyMember[]

  friendshipsAsLow  Friendship[] @relation("FriendshipLow")
  friendshipsAsHigh Friendship[] @relation("FriendshipHigh")

  inviteLinksCreated InviteLink[] @relation("InviteCreatedBy")

  expoPushTokens PlayerExpoPushToken[]

  dailyWords  PlayerDailyWord[]
  dailyStreaks PlayerDailyStreak[]
  venueVisitDays   PlayerVenueVisitDay[]
  venuePlayDays    PlayerVenuePlayDay[]
  venuePlayCountedGames PlayerVenuePlayCountedGame[]
  perkRedemptions  VenuePerkRedemption[] @relation("RedemptionGuest")
  offerRedemptions VenueOfferRedemption[]

  venueStaff VenueStaff[]
  staffInvitesSent VenueStaffInvite[] @relation("StaffInviteSentBy")
  /// Orgs this player created via partner self-serve onboarding (rate limits).
  selfServeOrganizationsCreated VenueOrganization[] @relation("SelfServeOrganizationsCreated")
  campaignSends VenueCampaignSend[]
  receiptSubmissions VenueReceiptSubmission[] @relation("ReceiptSubmitter")
  receiptsReviewed VenueReceiptSubmission[] @relation("ReceiptReviewer")
  redemptionsAcknowledged VenuePerkRedemption[] @relation("RedemptionStaffAck")
  redemptionsVoided VenuePerkRedemption[] @relation("RedemptionStaffVoid")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, username])
}

/// One row per player per venue per UTC calendar day — powers visits / badges / friend aggregates.
model PlayerVenueVisitDay {
  playerId  String
  venueId   String
  dayKey    String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([playerId, venueId, dayKey])
  @@index([venueId, dayKey])
  @@index([playerId, dayKey])
}

/// **Guest venue games started** per UTC calendar day (word solo / match / brawler at that venue).
model PlayerVenuePlayDay {
  playerId    String
  venueId     String
  dayKey      String
  gamesPlayed Int       @default(0)
  /// Dedupes repeated solo `/words/session` calls within this window as one game.
  lastSoloDeckAt DateTime?
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([playerId, venueId, dayKey])
  @@index([venueId, dayKey])
  @@index([playerId, dayKey])
}

/// One row per counted match/brawler `GameSession` so deck reloads / retries do not consume extra daily slots.
model PlayerVenuePlayCountedGame {
  id            String   @id @default(uuid())
  playerId      String
  venueId       String
  dayKey        String
  /// word_match | brawler
  kind          String
  gameSessionId String

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameSessionId, kind])
  @@index([playerId, dayKey])
}

/// Staff-configured perk codes (“show this screen for 10% off”).
model VenuePerk {
  id        String   @id @default(uuid())
  venueId   String
  /// Normalized uppercase code (unique globally for simple lookup).
  code      String   @unique
  title     String
  subtitle  String?
  body      String?
  requiresQrUnlock Boolean @default(false)
  activeFrom DateTime?
  activeTo   DateTime?
  maxRedemptions Int?
  redemptionCount Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue       Venue                 @relation(fields: [venueId], references: [id], onDelete: Cascade)
  redemptions VenuePerkRedemption[]

  @@index([venueId])
}

model VenuePerkRedemption {
  id         String   @id @default(uuid())
  perkId     String
  playerId   String
  venueId    String
  redeemedAt DateTime @default(now())

  staffAcknowledgedAt           DateTime?
  staffAcknowledgedByPlayerId   String?
  voidedAt                      DateTime?
  voidReason                    String?
  voidedByPlayerId              String?

  perk                 VenuePerk @relation(fields: [perkId], references: [id], onDelete: Cascade)
  player               Player    @relation("RedemptionGuest", fields: [playerId], references: [id], onDelete: Cascade)
  staffAcknowledgedBy  Player?   @relation("RedemptionStaffAck", fields: [staffAcknowledgedByPlayerId], references: [id], onDelete: SetNull)
  voidedBy             Player?   @relation("RedemptionStaffVoid", fields: [voidedByPlayerId], references: [id], onDelete: SetNull)

  @@unique([perkId, playerId])
  @@index([playerId])
  @@index([venueId])
  @@index([voidedAt])
}

/// Expo push notification token (one row per device token; reassigned on login).
model PlayerExpoPushToken {
  id        String   @id @default(uuid())
  playerId  String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

/// QR-unlock / membership for a physical venue (café).
model PlayerVenue {
  id        String   @id @default(uuid())
  playerId  String
  venueId   String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([playerId, venueId])
}

/// Per-venue XP; global XP = sum(venueXp) in queries.
model PlayerVenueStats {
  playerId String
  venueId  String
  venueXp  Int      @default(0)
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([playerId, venueId])
  @@index([venueId])
}

/// User subscription entitlements (e.g. “season pass”).
model Subscription {
  id        String    @id @default(uuid())
  playerId  String    @unique
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

/// Canonical friendship edge: playerLowId < playerHighId lexicographically.
model Friendship {
  id           String            @id @default(uuid())
  playerLowId  String
  playerHighId String
  status       FriendshipStatus
  /// Who initiated (must equal playerLowId or playerHighId).
  requestedById String

  playerLow  Player @relation("FriendshipLow", fields: [playerLowId], references: [id], onDelete: Cascade)
  playerHigh Player @relation("FriendshipHigh", fields: [playerHighId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerLowId, playerHighId])
  @@index([playerLowId])
  @@index([playerHighId])
}

model Party {
  id        String @id @default(uuid())
  name      String?
  creatorId String
  leaderId  String
  /// Max members from creator subscription at party creation (4 free, 200 subscriber).
  maxMembers Int

  creator Player @relation("PartyCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  leader  Player @relation("PartyLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members     PartyMember[]
  inviteLinks InviteLink[]
  gameSessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leaderId])
  @@index([creatorId])
}

model PartyMember {
  partyId  String
  playerId String
  joinedAt DateTime @default(now())

  party  Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([partyId, playerId])
  @@index([playerId])
}

enum InviteLinkKind {
  PARTY
  FRIEND
}

model InviteLink {
  id        String         @id @default(uuid())
  kind      InviteLinkKind
  tokenHash String         @unique

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  /// Leader (party) or inviter (friend): used for rate limits and auditing.
  createdById String
  createdBy   Player @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  expiresAt DateTime
  maxUses   Int
  useCount  Int       @default(0)
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([createdById])
  @@index([partyId])
}

/// Categories for word game vocabulary.
enum WordCategory {
  DRINK_FOOD
  PLACE_ATMOSPHERE
  MUSIC_CULTURE
  PEOPLE_ROLES
  MOMENTS_ACTIONS
}

/// A word that can appear in the word game, with hints for different difficulty levels.
model Word {
  id       String       @id @default(uuid())
  text     String
  language String       @default("en")
  category WordCategory

  /// Easy difficulty: full sentence hint.
  sentenceHint String
  /// Normal difficulty: list of related keywords.
  wordHints    String[]
  /// Hard difficulty: emojis / icon-like hints.
  emojiHints   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([text, language], name: "text_language")
}

/// One async “daily word” attempt record per player per calendar day (UTC) and scope (global or venue).
model PlayerDailyWord {
  id        String    @id @default(uuid())
  playerId  String
  dayKey    String
  scopeKey  String
  attempts  Int       @default(0)
  solvedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, dayKey, scopeKey])
  @@index([scopeKey, dayKey])
}

/// Consecutive daily-word solve streak per scope (global or venue id).
model PlayerDailyStreak {
  playerId         String
  scopeKey         String
  currentStreak    Int     @default(0)
  lastSolvedDayKey String?
  updatedAt        DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([playerId, scopeKey])
}

enum VenueFeedEventKind {
  WORD_MATCH_STARTED
  DAILY_WORD_SOLVED
}

/// Lightweight venue activity feed (“who’s playing what”).
model VenueFeedEvent {
  id              String             @id @default(uuid())
  venueId         String
  kind            VenueFeedEventKind
  title           String
  subtitle        String?
  actorUsername   String?
  createdAt       DateTime           @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

/// A single venue-scoped challenge that can be progressed by a player.
model Challenge {
  id                  String  @id @default(uuid())
  venueId             String
  title               String
  description         String?

  /// If true, rewards/claims require venue membership (QR-unlock) in addition to location rules.
  rewardVenueSpecific Boolean @default(true)

  /// If true, physical presence (detected venue match) is required to progress/complete.
  locationRequired    Boolean @default(false)

  /// For MVP, we model a simple "do X actions" challenge.
  targetCount Int @default(1)

  /// When true, progress and completion reset each ISO calendar week (UTC).
  resetsWeekly Boolean @default(false)

  /// Optional “happy hour” style window (UTC); null = always available.
  activeFrom DateTime?
  activeTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue    Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  progress ChallengeProgress[]

  @@index([venueId])
}

/// Per-player progress for a challenge.
model ChallengeProgress {
  id              String    @id @default(uuid())
  playerId        String
  challengeId     String

  progressCount   Int       @default(0)
  completedAt     DateTime?
  rewardClaimedAt DateTime?

  /// For `Challenge.resetsWeekly`: last ISO week key when progress was written (e.g. "2026-W11").
  periodKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([playerId, challengeId])
  @@index([challengeId])
}

enum GameType {
  WORD_GAME
  BRAWLER
}

enum GameSessionStatus {
  ACTIVE
  PENDING
  FINISHED
  CANCELLED
}

enum GameParticipantResult {
  WIN
  LOSS
  DRAW
}

enum GameEventType {
  SESSION_STARTED
  SESSION_ENDED
  PHASE_CHANGED
  ELIMINATION
  SCORE_CHANGED
  POWERUP_PICKED
  CUSTOM
}

enum BrawlerPhase {
  CHAOS
  ENDGAME
  SUDDEN_DEATH
}

model GameSession {
  id          String            @id @default(uuid())
  gameType    GameType
  status      GameSessionStatus @default(PENDING)
  /// Short code so friends can join a pending word match (co-op / versus).
  inviteCode  String?           @unique
  /// Optional context links for your existing ecosystem.
  venueId     String?
  partyId     String?
  /// Version + optional snapshot for balance/config reproducibility.
  configVersion Int             @default(1)
  config        Json?
  startedAt   DateTime?
  endedAt     DateTime?
  /// Winner stored at participant level (supports bots + non-player entities).
  winnerParticipantId String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  venue       Venue?            @relation(fields: [venueId], references: [id], onDelete: SetNull)
  party       Party?            @relation(fields: [partyId], references: [id], onDelete: SetNull)
  participants GameParticipant[]
  events       GameEvent[]
  /// 1:1 extensions (nullable unless that gameType applies)
  brawlerSession BrawlerSession?
  wordSession    WordSession?
  @@index([gameType, status, createdAt])
  @@index([startedAt])
  @@index([endedAt])
  @@index([venueId, gameType, createdAt])
  @@index([partyId, createdAt])
}

model GameParticipant {
  id           String  @id @default(uuid())
  sessionId    String
  /// Either playerId set OR isBot=true (+ bot fields), depending on participant kind.
  playerId     String?
  isBot        Boolean @default(false)
  botName      String?
  /// Snapshot fields prevent historical drift if user profile changes.
  displayNameSnapshot String?
  characterSnapshot   String? // e.g., selected hero/skin identifier
  brawlerHeroId       String?
  /// Optional immutable snapshot of hero tuning at match start.
  heroSnapshot        Json?
  joinedAt     DateTime @default(now())
  leftAt       DateTime?
  placement    Int?
  score        Int      @default(0)
  result       GameParticipantResult?
  /// Generic combat/participation counters useful across many games.
  kills        Int      @default(0)
  deaths       Int      @default(0)
  assists      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  session      GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player       Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)
  brawlerHero  BrawlerHero? @relation(fields: [brawlerHeroId], references: [id], onDelete: SetNull)
  /// Event links (participant-centric)
  actorEvents  GameEvent[] @relation("GameEventActor")
  targetEvents GameEvent[] @relation("GameEventTarget")
  /// 1:1 extensions
  brawlerStats BrawlerParticipantStats?
  wordStats    WordParticipantStats?
  @@index([sessionId])
  @@index([playerId, createdAt])
  @@index([sessionId, placement])
  @@index([sessionId, score])
  @@index([brawlerHeroId])
  @@unique([sessionId, playerId], map: "unique_player_per_session")
}

model GameEvent {
  id           String        @id @default(uuid())
  sessionId    String
  gameType     GameType
  eventType    GameEventType
  /// Timestamp relative to match start, useful for deterministic ordering.
  atMs         Int
  actorParticipantId  String?
  targetParticipantId String?
  payload      Json?
  createdAt    DateTime @default(now())
  session      GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor        GameParticipant? @relation("GameEventActor", fields: [actorParticipantId], references: [id], onDelete: SetNull)
  target       GameParticipant? @relation("GameEventTarget", fields: [targetParticipantId], references: [id], onDelete: SetNull)
  @@index([sessionId, atMs])
  @@index([gameType, eventType, createdAt])
  @@index([actorParticipantId])
  @@index([targetParticipantId])
}

model PlayerGameStats {
  playerId       String
  gameType       GameType
  matchesPlayed  Int      @default(0)
  wins           Int      @default(0)
  losses         Int      @default(0)
  draws          Int      @default(0)
  dnfs           Int      @default(0)
  totalKills     Int      @default(0)
  totalDeaths    Int      @default(0)
  totalAssists   Int      @default(0)
  totalScore     Int      @default(0)
  bestPlacement  Int?
  winRate        Float    @default(0)
  firstPlayedAt  DateTime?
  lastPlayedAt   DateTime?
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@id([playerId, gameType])
  @@index([gameType, wins])
  @@index([gameType, winRate])
  @@index([gameType, lastPlayedAt])
}

model PlayerGameVenueStats {
  playerId       String
  venueId        String
  gameType       GameType
  matchesPlayed  Int      @default(0)
  wins           Int      @default(0)
  totalScore     Int      @default(0)
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue          Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  @@id([playerId, venueId, gameType])
  @@index([venueId, gameType, wins])
  @@index([venueId, gameType, totalScore])
}

model BrawlerSession {
  sessionId            String @id
  chaosDurationMs      Int    @default(45000)
  endgameDurationMs    Int    @default(15000)
  suddenDeathMaxMs     Int    @default(15000)
  respawnDelayMs       Int    @default(3000)
  lavaStartsAtMs       Int    @default(45000)
  platformsCollapseAtMs Int   @default(45000)
  /// Optional seed for deterministic simulation/replay.
  rngSeed              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  session              GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model BrawlerHero {
  id               String  @id
  name             String
  isActive         Boolean @default(true)
  /// Optional role/archetype label, e.g. "Bruiser", "Trickster".
  archetype        String?
  /// UI avatar used in menus, profiles, and leaderboard rows.
  avatarImageUrl   String?
  /// Optional larger portrait for hero select and detail views.
  portraitImageUrl String?
  /// Sprite sheet/atlas URL for in-game animations.
  spriteSheetUrl   String?
  /// Frame and animation metadata (frame size, fps, animation map, etc).
  spriteMeta       Json?

  baseHp           Int
  moveSpeed        Float
  dashCooldownMs   Int
  attackDamage     Int
  attackKnockback  Float

  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gameParticipants GameParticipant[]

  @@index([isActive])
  @@index([name])
}

model BrawlerParticipantStats {
  participantId        String @id
  damageDealt          Int    @default(0)
  damageTaken          Int    @default(0)
  ringOuts             Int    @default(0)
  falls                Int    @default(0)
  respawns             Int    @default(0)
  powerupsPicked       Int    @default(0)
  powerupsUsed         Int    @default(0)
  longestSurvivalMs    Int    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  participant          GameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  @@index([damageDealt])
  @@index([ringOuts])
}

model WordSession {
  sessionId            String @id
  roundCount           Int    @default(1)
  language             String @default("en")
  /// Co-op: shared progress index into the ordered word list (server-authoritative).
  sharedWordIndex      Int    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  session              GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
model WordParticipantStats {
  participantId        String @id
  correctAnswers       Int    @default(0)
  wrongAnswers         Int    @default(0)
  streakBest           Int    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  participant          GameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  @@index([correctAnswers])
}