generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// A physical venue (café, bar, etc.) where games can be played.
model Venue {
  id           String @id @default(uuid())
  name         String
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int    @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A user profile inside Cafe Social.
model Player {
  id       String @id @default(uuid())
  email    String @unique
  username String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, username])
}

/// Categories for word game vocabulary.
enum WordCategory {
  DRINK_FOOD
  PLACE_ATMOSPHERE
  MUSIC_CULTURE
  PEOPLE_ROLES
  MOMENTS_ACTIONS
}

/// A word that can appear in the word game, with hints for different difficulty levels.
model Word {
  id       String       @id @default(uuid())
  text     String
  language String       @default("en")
  category WordCategory

  /// Easy difficulty: full sentence hint.
  sentenceHint String
  /// Normal difficulty: list of related keywords.
  wordHints    String[]
  /// Hard difficulty: emojis / icon-like hints.
  emojiHints   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([text, language], name: "text_language")
}


