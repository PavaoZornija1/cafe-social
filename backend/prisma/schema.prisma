generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// A physical venue (café, bar, etc.) where games can be played.
model Venue {
  id           String  @id @default(uuid())
  name         String
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int     @default(50)
  isPremium    Boolean @default(false)

  /// Geo ladder (venue → city → country → region → global)
  city    String?
  country String?
  region  String?

  playerVenues     PlayerVenue[]
  playerVenueStats PlayerVenueStats[]
  challenges       Challenge[]
  gameSessions         GameSession[]
  playerGameVenueStats PlayerGameVenueStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A user profile inside Cafe Social.
model Player {
  id       String @id @default(uuid())
  email    String @unique
  username String @unique

  /// Open to being seen / challenged (default on). Subscribers get extra remote discoverability when this is on.
  discoverable Boolean @default(true)
  /// Total privacy: invisible to everyone for social/presence surfaces.
  totalPrivacy Boolean @default(false)

  lastPresenceVenueId String?
  lastPresenceAt      DateTime?

  playerVenues        PlayerVenue[]
  playerVenueStats    PlayerVenueStats[]
  subscriptions       Subscription[]
  challengeProgress   ChallengeProgress[]

  gameParticipants     GameParticipant[]
  gameStats      PlayerGameStats[]
  gameVenueStats PlayerGameVenueStats[]

  partiesCreated    Party[]       @relation("PartyCreator")
  partiesLed        Party[]       @relation("PartyLeader")
  partyMemberships  PartyMember[]

  friendshipsAsLow  Friendship[] @relation("FriendshipLow")
  friendshipsAsHigh Friendship[] @relation("FriendshipHigh")

  inviteLinksCreated InviteLink[] @relation("InviteCreatedBy")

  expoPushTokens PlayerExpoPushToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, username])
}

/// Expo push notification token (one row per device token; reassigned on login).
model PlayerExpoPushToken {
  id        String   @id @default(uuid())
  playerId  String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

/// QR-unlock / membership for a physical venue (café).
model PlayerVenue {
  id        String   @id @default(uuid())
  playerId  String
  venueId   String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([playerId, venueId])
}

/// Per-venue XP; global XP = sum(venueXp) in queries.
model PlayerVenueStats {
  playerId String
  venueId  String
  venueXp  Int      @default(0)
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@id([playerId, venueId])
  @@index([venueId])
}

/// User subscription entitlements (e.g. “season pass”).
model Subscription {
  id        String    @id @default(uuid())
  playerId  String    @unique
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

/// Canonical friendship edge: playerLowId < playerHighId lexicographically.
model Friendship {
  id           String            @id @default(uuid())
  playerLowId  String
  playerHighId String
  status       FriendshipStatus
  /// Who initiated (must equal playerLowId or playerHighId).
  requestedById String

  playerLow  Player @relation("FriendshipLow", fields: [playerLowId], references: [id], onDelete: Cascade)
  playerHigh Player @relation("FriendshipHigh", fields: [playerHighId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerLowId, playerHighId])
  @@index([playerLowId])
  @@index([playerHighId])
}

model Party {
  id        String @id @default(uuid())
  name      String?
  creatorId String
  leaderId  String
  /// Max members from creator subscription at party creation (4 free, 200 subscriber).
  maxMembers Int

  creator Player @relation("PartyCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  leader  Player @relation("PartyLeader", fields: [leaderId], references: [id], onDelete: Cascade)

  members     PartyMember[]
  inviteLinks InviteLink[]
  gameSessions GameSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leaderId])
  @@index([creatorId])
}

model PartyMember {
  partyId  String
  playerId String
  joinedAt DateTime @default(now())

  party  Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([partyId, playerId])
  @@index([playerId])
}

enum InviteLinkKind {
  PARTY
  FRIEND
}

model InviteLink {
  id        String         @id @default(uuid())
  kind      InviteLinkKind
  tokenHash String         @unique

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  /// Leader (party) or inviter (friend): used for rate limits and auditing.
  createdById String
  createdBy   Player @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  expiresAt DateTime
  maxUses   Int
  useCount  Int       @default(0)
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([createdById])
  @@index([partyId])
}

/// Categories for word game vocabulary.
enum WordCategory {
  DRINK_FOOD
  PLACE_ATMOSPHERE
  MUSIC_CULTURE
  PEOPLE_ROLES
  MOMENTS_ACTIONS
}

/// A word that can appear in the word game, with hints for different difficulty levels.
model Word {
  id       String       @id @default(uuid())
  text     String
  language String       @default("en")
  category WordCategory

  /// Easy difficulty: full sentence hint.
  sentenceHint String
  /// Normal difficulty: list of related keywords.
  wordHints    String[]
  /// Hard difficulty: emojis / icon-like hints.
  emojiHints   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([text, language], name: "text_language")
}

/// A single venue-scoped challenge that can be progressed by a player.
model Challenge {
  id                  String  @id @default(uuid())
  venueId             String
  title               String
  description         String?

  /// If true, rewards/claims require venue membership (QR-unlock) in addition to location rules.
  rewardVenueSpecific Boolean @default(true)

  /// If true, physical presence (detected venue match) is required to progress/complete.
  locationRequired    Boolean @default(false)

  /// For MVP, we model a simple "do X actions" challenge.
  targetCount Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue    Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  progress ChallengeProgress[]

  @@index([venueId])
}

/// Per-player progress for a challenge.
model ChallengeProgress {
  id              String    @id @default(uuid())
  playerId        String
  challengeId     String

  progressCount   Int       @default(0)
  completedAt     DateTime?
  rewardClaimedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([playerId, challengeId])
  @@index([challengeId])
}

enum GameType {
  WORD_GAME
  BRAWLER
}

enum GameSessionStatus {
  ACTIVE
  PENDING
  FINISHED
  CANCELLED
}

enum GameParticipantResult {
  WIN
  LOSS
  DRAW
}

enum GameEventType {
  SESSION_STARTED
  SESSION_ENDED
  PHASE_CHANGED
  ELIMINATION
  SCORE_CHANGED
  POWERUP_PICKED
  CUSTOM
}

enum BrawlerPhase {
  CHAOS
  ENDGAME
  SUDDEN_DEATH
}

model GameSession {
  id          String            @id @default(uuid())
  gameType    GameType
  status      GameSessionStatus @default(PENDING)
  /// Short code so friends can join a pending word match (co-op / versus).
  inviteCode  String?           @unique
  /// Optional context links for your existing ecosystem.
  venueId     String?
  partyId     String?
  /// Version + optional snapshot for balance/config reproducibility.
  configVersion Int             @default(1)
  config        Json?
  startedAt   DateTime?
  endedAt     DateTime?
  /// Winner stored at participant level (supports bots + non-player entities).
  winnerParticipantId String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  venue       Venue?            @relation(fields: [venueId], references: [id], onDelete: SetNull)
  party       Party?            @relation(fields: [partyId], references: [id], onDelete: SetNull)
  participants GameParticipant[]
  events       GameEvent[]
  /// 1:1 extensions (nullable unless that gameType applies)
  brawlerSession BrawlerSession?
  wordSession    WordSession?
  @@index([gameType, status, createdAt])
  @@index([startedAt])
  @@index([endedAt])
  @@index([venueId, gameType, createdAt])
  @@index([partyId, createdAt])
}

model GameParticipant {
  id           String  @id @default(uuid())
  sessionId    String
  /// Either playerId set OR isBot=true (+ bot fields), depending on participant kind.
  playerId     String?
  isBot        Boolean @default(false)
  botName      String?
  /// Snapshot fields prevent historical drift if user profile changes.
  displayNameSnapshot String?
  characterSnapshot   String? // e.g., selected hero/skin identifier
  brawlerHeroId       String?
  /// Optional immutable snapshot of hero tuning at match start.
  heroSnapshot        Json?
  joinedAt     DateTime @default(now())
  leftAt       DateTime?
  placement    Int?
  score        Int      @default(0)
  result       GameParticipantResult?
  /// Generic combat/participation counters useful across many games.
  kills        Int      @default(0)
  deaths       Int      @default(0)
  assists      Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  session      GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player       Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)
  brawlerHero  BrawlerHero? @relation(fields: [brawlerHeroId], references: [id], onDelete: SetNull)
  /// Event links (participant-centric)
  actorEvents  GameEvent[] @relation("GameEventActor")
  targetEvents GameEvent[] @relation("GameEventTarget")
  /// 1:1 extensions
  brawlerStats BrawlerParticipantStats?
  wordStats    WordParticipantStats?
  @@index([sessionId])
  @@index([playerId, createdAt])
  @@index([sessionId, placement])
  @@index([sessionId, score])
  @@index([brawlerHeroId])
  @@unique([sessionId, playerId], map: "unique_player_per_session")
}

model GameEvent {
  id           String        @id @default(uuid())
  sessionId    String
  gameType     GameType
  eventType    GameEventType
  /// Timestamp relative to match start, useful for deterministic ordering.
  atMs         Int
  actorParticipantId  String?
  targetParticipantId String?
  payload      Json?
  createdAt    DateTime @default(now())
  session      GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor        GameParticipant? @relation("GameEventActor", fields: [actorParticipantId], references: [id], onDelete: SetNull)
  target       GameParticipant? @relation("GameEventTarget", fields: [targetParticipantId], references: [id], onDelete: SetNull)
  @@index([sessionId, atMs])
  @@index([gameType, eventType, createdAt])
  @@index([actorParticipantId])
  @@index([targetParticipantId])
}

model PlayerGameStats {
  playerId       String
  gameType       GameType
  matchesPlayed  Int      @default(0)
  wins           Int      @default(0)
  losses         Int      @default(0)
  draws          Int      @default(0)
  dnfs           Int      @default(0)
  totalKills     Int      @default(0)
  totalDeaths    Int      @default(0)
  totalAssists   Int      @default(0)
  totalScore     Int      @default(0)
  bestPlacement  Int?
  winRate        Float    @default(0)
  firstPlayedAt  DateTime?
  lastPlayedAt   DateTime?
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@id([playerId, gameType])
  @@index([gameType, wins])
  @@index([gameType, winRate])
  @@index([gameType, lastPlayedAt])
}

model PlayerGameVenueStats {
  playerId       String
  venueId        String
  gameType       GameType
  matchesPlayed  Int      @default(0)
  wins           Int      @default(0)
  totalScore     Int      @default(0)
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  venue          Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  @@id([playerId, venueId, gameType])
  @@index([venueId, gameType, wins])
  @@index([venueId, gameType, totalScore])
}

model BrawlerSession {
  sessionId            String @id
  chaosDurationMs      Int    @default(45000)
  endgameDurationMs    Int    @default(15000)
  suddenDeathMaxMs     Int    @default(15000)
  respawnDelayMs       Int    @default(3000)
  lavaStartsAtMs       Int    @default(45000)
  platformsCollapseAtMs Int   @default(45000)
  /// Optional seed for deterministic simulation/replay.
  rngSeed              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  session              GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model BrawlerHero {
  id               String  @id
  name             String
  isActive         Boolean @default(true)
  /// Optional role/archetype label, e.g. "Bruiser", "Trickster".
  archetype        String?
  /// UI avatar used in menus, profiles, and leaderboard rows.
  avatarImageUrl   String?
  /// Optional larger portrait for hero select and detail views.
  portraitImageUrl String?
  /// Sprite sheet/atlas URL for in-game animations.
  spriteSheetUrl   String?
  /// Frame and animation metadata (frame size, fps, animation map, etc).
  spriteMeta       Json?

  baseHp           Int
  moveSpeed        Float
  dashCooldownMs   Int
  attackDamage     Int
  attackKnockback  Float

  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gameParticipants GameParticipant[]

  @@index([isActive])
  @@index([name])
}

model BrawlerParticipantStats {
  participantId        String @id
  damageDealt          Int    @default(0)
  damageTaken          Int    @default(0)
  ringOuts             Int    @default(0)
  falls                Int    @default(0)
  respawns             Int    @default(0)
  powerupsPicked       Int    @default(0)
  powerupsUsed         Int    @default(0)
  longestSurvivalMs    Int    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  participant          GameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  @@index([damageDealt])
  @@index([ringOuts])
}

model WordSession {
  sessionId            String @id
  roundCount           Int    @default(1)
  language             String @default("en")
  /// Co-op: shared progress index into the ordered word list (server-authoritative).
  sharedWordIndex      Int    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  session              GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
model WordParticipantStats {
  participantId        String @id
  correctAnswers       Int    @default(0)
  wrongAnswers         Int    @default(0)
  streakBest           Int    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  participant          GameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  @@index([correctAnswers])
}